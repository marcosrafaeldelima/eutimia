# LinkedIn Integration
# Copie este arquivo como .env.local e preencha com seus dados

# Access Token pessoal de Flávia (LinkedIn)
# Como obter: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# ID do perfil de Flávia
# Como obter: https://www.linkedin.com/in/flaviaconti/ (numerais do URL)
LINKEDIN_PROFILE_ID=your_profile_id_here
