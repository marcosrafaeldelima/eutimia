{
  "name": "eutimia",
  "version": "1.0.0",
  "description": "Eutimia — Plataforma de bem-estar digital",
  "main": "dist/index.html",
  "scripts": {
    "dev": "serve src",
    "build": "echo 'Build complete' && cp -r src/* dist/ 2>/dev/null || robocopy src dist /S",
    "start": "serve .",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "lint": "prettier --check \"src/**/*.{js,css,html}\""
  },
  "keywords": [
    "wellness",
    "bem-estar",
    "digital",
    "saúde mental"
  ],
  "author": "Marcos Rafael de Lima",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.0.0",
    "serve": "^14.2.0"
  },
  "dependencies": {}
}
